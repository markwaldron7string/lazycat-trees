# ──────────────────────────────────────────────────────────
# LazyCat Trees - Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ──────────────────────────────────────────────────────────

# ── Stripe ─────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Webhook secret (from Stripe Dashboard > Webhooks)
# Only needed if you add a /api/stripe-webhook route for post-payment automation
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Resend ─────────────────────────────────────────────────
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_...

# ── Email ──────────────────────────────────────────────────
# Where contact form submissions and commission requests are sent
CONTACT_EMAIL=owner@lazycattrees.com

# ── Site URL ───────────────────────────────────────────────
# Used for Stripe success/cancel redirect URLs
# Local development:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production (set this in Vercel dashboard):
# NEXT_PUBLIC_SITE_URL=https://lazycattrees.com
